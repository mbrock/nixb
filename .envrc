use flake
export CCACHE_MAXSIZE=50G
export CCACHE_ABSSTDERR=1

# Auto-generate .clangd with nix store paths for clangd to find headers
if [ -n "$NIX_CFLAGS_COMPILE" ]; then
  {
    echo "CompileFlags:"
    echo "  Add:"
    # Add gcc toolchain from flake's gcc
    echo "    - --gcc-toolchain=/nix/store/8adzgnxs3s0pbj22qhk9zjxi1fqmz3xv-gcc-14.3.0"
    echo "    - -isystem/nix/store/8adzgnxs3s0pbj22qhk9zjxi1fqmz3xv-gcc-14.3.0/lib/gcc/x86_64-unknown-linux-gnu/14.3.0/include"
    # Add all isystem paths from nix
    for flag in $NIX_CFLAGS_COMPILE; do
      case "$flag" in
        -isystem) ;;
        /*) echo "    - -isystem$flag" ;;
      esac
    done
  } > .clangd
fi
